# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Explicitly declare text files
*.py text
*.js text
*.jsx text
*.ts text
*.tsx text
*.json text
*.css text
*.scss text
*.html text
*.md text
*.yml text
*.yaml text
*.toml text
*.ini text
*.sh text
*.sql text

# Declare files that will always have CRLF line endings on checkout
# *.bat text eol=crlf

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
