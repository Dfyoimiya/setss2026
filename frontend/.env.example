# ============================================
# Frontend Environment Variables (.env.local)
# ============================================
# Copy this file to .env.local and fill in real values.
# DO NOT commit .env.local to Git.

# Backend API base URL (used by Vite dev server proxy)
VITE_API_BASE_URL=http://localhost:8001

# Public MinIO endpoint (for direct file access from browser)
VITE_MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# App configuration
VITE_APP_TITLE=SETSS 2026
VITE_APP_DEFAULT_LANGUAGE=zh
